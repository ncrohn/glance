<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- WKWebView's JavaScriptCore needs writable/JIT executable memory under
	     the hardened runtime that notarization requires. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<!-- The bundled glance-mcp sidecar is signed with the same Developer ID,
	     so library validation can stay on; disabling it would only be needed
	     for third-party/unsigned dylibs. Kept off intentionally. -->
</dict>
</plist>
